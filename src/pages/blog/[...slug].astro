---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;
type AdjacentPost = Pick<CollectionEntry<'blog'>, 'id' | 'data'>;

const post = Astro.props;
const { Content } = await render(post);
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const currentPostIndex = posts.findIndex((entry) => entry.id === post.id);
const prevPost: AdjacentPost | undefined =
	currentPostIndex > 0 ? posts[currentPostIndex - 1] : undefined;
const nextPost: AdjacentPost | undefined =
	currentPostIndex >= 0 && currentPostIndex < posts.length - 1
		? posts[currentPostIndex + 1]
		: undefined;
---

<BlogPost {...post.data} prevPost={prevPost} nextPost={nextPost}>
	<Content />
</BlogPost>
