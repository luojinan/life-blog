---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import BlogFooter from "../components/BlogFooter.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { countChineseCharacters } from "../utils/countChineseCharacters";

const posts = (await getCollection("blog"))
  .map((post) => ({
    ...post,
    wordCount: countChineseCharacters(post.body ?? ""),
  }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type PostItem = (typeof posts)[number] & { index: number };
type YearGroup = {
  year: number;
  posts: PostItem[];
};

const yearGroups = posts.reduce<YearGroup[]>((groups, post, index) => {
  const year = post.data.date.getFullYear();
  const postItem = {
    ...post,
    index,
  };
  const currentGroup = groups.at(-1);

  if (currentGroup && currentGroup.year === year) {
    currentGroup.posts.push(postItem);
    return groups;
  }

  groups.push({
    year,
    posts: [postItem],
  });
  return groups;
}, []);

const pageSize = 20;
const totalPages = Math.max(1, Math.ceil(posts.length / pageSize));
const initialYear = String(yearGroups[0]?.year ?? "");

const createYearMaskDataUri = (year: string) => {
  const safeYear = year || "0000";
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 420"><text x="100%" y="73%" text-anchor="end" font-family="Iowan Old Style, Baskerville, Georgia, serif" font-size="320" font-weight="700" letter-spacing="-18" fill="black">${safeYear}</text></svg>`;

  return `url("data:image/svg+xml,${encodeURIComponent(svg)}")`;
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: min(760px, calc(100% - 2rem));
        padding-block: 2.75rem 4rem;
      }

      .post-archive {
        position: relative;
      }

      .year-backdrop {
        position: sticky;
        top: clamp(5.5rem, 16vh, 8.5rem);
        z-index: 0;
        height: clamp(7.5rem, 22vw, 12rem);
        margin-bottom: calc(clamp(7.5rem, 22vw, 12rem) * -1);
        pointer-events: none;
      }

      .year-backdrop[hidden] {
        display: none;
      }

      .year-backdrop-label {
        display: block;
        width: 100%;
        height: 100%;
        background: rgba(var(--color-text-strong), 0.09);
        opacity: 0;
        transform: translateY(-12%);
        transform-origin: right center;
        transition:
          opacity 0.28s ease,
          transform 0.28s ease,
          background-color 0.2s ease;
        -webkit-mask-image: var(--year-mask-image);
        mask-image: var(--year-mask-image);
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: right center;
        mask-position: right center;
        -webkit-mask-size: min(100%, 34rem) auto;
        mask-size: min(100%, 34rem) auto;
      }

      .post-archive[data-active-year] .year-backdrop-label {
        opacity: 1;
        transform: translateY(0);
      }

      .post-grid {
        position: relative;
        z-index: 1;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .year-group {
        list-style: none;
      }

      .year-group[hidden] {
        display: none;
      }

      .year-divider {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        margin: 0;
        padding: 1.5rem 0 0.35rem;
        color: rgb(var(--color-text-muted));
        font-size: 0.9rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
      }

      .year-divider::before {
        content: "";
        flex: 1 1 auto;
        height: 1px;
        background: linear-gradient(
          90deg,
          rgba(var(--color-border), 0.28),
          rgba(var(--color-border), 0.85)
        );
        order: 2;
      }

      .year-divider span {
        order: 1;
      }

      .year-group-posts {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .post-card {
        border-bottom: 1px solid rgba(var(--color-border), 0.7);
        background: transparent;
      }

      .post-card[hidden] {
        display: none;
      }

      .post-link {
        display: grid;
        gap: 0.45rem;
        padding: 1.2rem 0;
        color: inherit;
        text-decoration: none;
      }

      .post-date {
        margin: 0;
        color: rgb(var(--color-text-muted));
        font-size: 0.92rem;
        line-height: 1.4;
      }

      .post-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
      }

      .post-word-count {
        color: rgb(var(--color-text-muted));
        font-size: 0.92rem;
        line-height: 1.4;
      }

      .post-title {
        margin: 0;
        color: rgb(var(--color-text-strong));
        font-size: clamp(1.15rem, 2vw, 1.45rem);
        font-weight: 700;
        line-height: 1.3;
        letter-spacing: -0.02em;
        word-break: break-word;
      }

      .pagination {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.35rem 0.5rem;
        padding-top: 1.5rem;
      }

      .pagination[hidden] {
        display: none;
      }

      .pagination button {
        padding: 0.35rem 0.55rem;
        border: none;
        background: transparent;
        color: rgb(var(--color-text));
        cursor: pointer;
        font: inherit;
        font-size: 0.95rem;
      }

      .pagination button:disabled {
        cursor: not-allowed;
        opacity: 0.45;
      }

      .pagination button[aria-current="page"] {
        color: var(--accent);
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }

      @media (max-width: 720px) {
        main {
          width: min(100%, calc(100% - 1rem));
          padding-block: 1rem;
        }

        .year-backdrop {
          top: 5.35rem;
          height: clamp(5rem, 28vw, 7rem);
          margin-bottom: calc(clamp(5rem, 28vw, 7rem) * -1);
        }

        .year-backdrop-label {
          -webkit-mask-size: min(100%, 16rem) auto;
          mask-size: min(100%, 16rem) auto;
          background: rgba(var(--color-text-strong), 0.08);
        }

        .year-divider {
          padding-top: 1.1rem;
          font-size: 0.76rem;
          letter-spacing: 0.2em;
        }

        .post-link {
          padding: 1rem 0;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="post-archive" data-post-archive aria-label="Blog list">
        <div class="year-backdrop" data-year-backdrop hidden={!initialYear}>
          <span
            class="year-backdrop-label"
            data-year-backdrop-label
            style={`--year-mask-image: ${createYearMaskDataUri(initialYear)}`}
          ></span>
        </div>
        <ul
          class="post-grid"
          data-post-list
          data-page-size={pageSize}
          aria-label="Blog posts"
        >
          {
            yearGroups.map((group) => (
              <li class="year-group" data-year-group data-year={group.year}>
                <p class="year-divider">
                  <span>{group.year}</span>
                </p>
                <ul class="year-group-posts" aria-label={`${group.year} posts`}>
                  {group.posts.map((post) => (
                    <li class="post-card" data-post-item data-post-index={post.index}>
                      <a class="post-link" href={`/blog/${post.id}/`}>
                        <div class="post-card-header">
                          <div class="post-meta">
                            <p class="post-date">
                              <FormattedDate date={post.data.date} />
                            </p>
                            <span class="post-word-count">{post.wordCount} 字</span>
                          </div>
                          <h2 class="post-title">{post.data.title}</h2>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ))
          }
        </ul>

        <nav
          class="pagination"
          data-pagination
          aria-label="Pagination"
          hidden={totalPages <= 1}
        >
          <button type="button" data-pagination-prev>上一页</button>
          {
            Array.from({ length: totalPages }, (_, index) => (
              <button type="button" data-pagination-page={index + 1}>
                {index + 1}
              </button>
            ))
          }
          <button type="button" data-pagination-next>下一页</button>
        </nav>
      </section>
      <BlogFooter maxWidth="760px" />
    </main>

    <script>
      const buildYearMask = (year) => {
        const safeYear = year || "0000";
        const svg =
          `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 420">` +
          `<text x="100%" y="73%" text-anchor="end" font-family="Iowan Old Style, Baskerville, Georgia, serif" font-size="320" font-weight="700" letter-spacing="-18" fill="black">${safeYear}</text>` +
          `</svg>`;

        return `url("data:image/svg+xml,${encodeURIComponent(svg)}")`;
      };

      const postList = document.querySelector("[data-post-list]");
      const pagination = document.querySelector("[data-pagination]");
      const archive = document.querySelector("[data-post-archive]");
      const yearBackdrop = document.querySelector("[data-year-backdrop]");
      const yearBackdropLabel = document.querySelector(
        "[data-year-backdrop-label]",
      );

      if (postList instanceof HTMLElement && archive instanceof HTMLElement) {
        const postItems = Array.from(
          postList.querySelectorAll("[data-post-item]"),
        );
        const yearGroups = Array.from(
          postList.querySelectorAll("[data-year-group]"),
        ).map((group) => ({
          element: group,
          year: group.getAttribute("data-year") || "",
          items: Array.from(group.querySelectorAll("[data-post-item]")),
        }));
        const pageSize = Number(postList.dataset.pageSize) || 20;
        const totalPages = Math.max(1, Math.ceil(postItems.length / pageSize));
        const previousButton =
          pagination instanceof HTMLElement
            ? pagination.querySelector("[data-pagination-prev]")
            : null;
        const nextButton =
          pagination instanceof HTMLElement
            ? pagination.querySelector("[data-pagination-next]")
            : null;
        const pageButtons =
          pagination instanceof HTMLElement
            ? Array.from(pagination.querySelectorAll("[data-pagination-page]"))
            : [];
        const sectionTop = postList.closest("section");
        let currentPage = 1;
        let activeYear = archive.dataset.activeYear || "";
        let syncFrame = 0;

        const setActiveYear = (year) => {
          if (!year || activeYear === year) return;
          activeYear = year;
          archive.dataset.activeYear = year;

          if (yearBackdrop instanceof HTMLElement) {
            yearBackdrop.hidden = false;
          }

          if (yearBackdropLabel instanceof HTMLElement) {
            yearBackdropLabel.style.setProperty(
              "--year-mask-image",
              buildYearMask(year),
            );
          }
        };

        const syncVisibleYearGroups = () => {
          yearGroups.forEach((group) => {
            const hasVisiblePosts = group.items.some((item) => !item.hidden);
            group.element.hidden = !hasVisiblePosts;
          });
        };

        const syncActiveYear = () => {
          const visibleGroups = yearGroups.filter(
            (group) => !group.element.hidden,
          );

          if (!visibleGroups.length) {
            archive.removeAttribute("data-active-year");
            activeYear = "";
            if (yearBackdrop instanceof HTMLElement) {
              yearBackdrop.hidden = true;
            }
            return;
          }

          const viewportHeight =
            window.innerHeight || document.documentElement.clientHeight;
          const sectionRect = archive.getBoundingClientRect();
          const isSectionVisible =
            sectionRect.bottom > 96 && sectionRect.top < viewportHeight - 48;

          if (yearBackdrop instanceof HTMLElement) {
            yearBackdrop.hidden = !isSectionVisible;
          }

          if (!isSectionVisible) return;

          const activationLine = Math.min(
            Math.max(viewportHeight * 0.28, 120),
            240,
          );
          const visibleRects = visibleGroups
            .map((group) => ({
              group,
              rect: group.element.getBoundingClientRect(),
            }))
            .filter(
              ({ rect }) => rect.bottom > 0 && rect.top < viewportHeight,
            );
          const passedGroup = visibleRects
            .filter(({ rect }) => rect.top <= activationLine)
            .at(-1)?.group;
          const fallbackGroup = visibleRects[0]?.group || visibleGroups[0];

          setActiveYear(passedGroup?.year || fallbackGroup.year);
        };

        const queueSyncActiveYear = () => {
          if (syncFrame) return;
          syncFrame = window.requestAnimationFrame(() => {
            syncFrame = 0;
            syncActiveYear();
          });
        };

        const renderPage = (page, scrollToTop = false) => {
          currentPage = Math.min(Math.max(page, 1), totalPages);
          const start = (currentPage - 1) * pageSize;
          const end = start + pageSize;

          postItems.forEach((item, index) => {
            item.hidden = index < start || index >= end;
          });

          pageButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const buttonPage = Number(button.dataset.paginationPage);
            if (buttonPage === currentPage) {
              button.setAttribute("aria-current", "page");
            } else {
              button.removeAttribute("aria-current");
            }
          });

          if (previousButton instanceof HTMLButtonElement) {
            previousButton.disabled = currentPage === 1;
          }

          if (nextButton instanceof HTMLButtonElement) {
            nextButton.disabled = currentPage === totalPages;
          }

          syncVisibleYearGroups();
          syncActiveYear();

          if (scrollToTop && sectionTop instanceof HTMLElement) {
            sectionTop.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        };

        pageButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener("click", () => {
            renderPage(Number(button.dataset.paginationPage), true);
          });
        });

        if (previousButton instanceof HTMLButtonElement) {
          previousButton.addEventListener("click", () => {
            renderPage(currentPage - 1, true);
          });
        }

        if (nextButton instanceof HTMLButtonElement) {
          nextButton.addEventListener("click", () => {
            renderPage(currentPage + 1, true);
          });
        }

        window.addEventListener("scroll", queueSyncActiveYear, {
          passive: true,
        });
        window.addEventListener("resize", queueSyncActiveYear);

        renderPage(1);
      }
    </script>
  </body>
</html>
