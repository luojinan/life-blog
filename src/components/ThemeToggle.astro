<button
	type="button"
	class="theme-toggle"
	data-theme-toggle
	aria-label="切换到深色主题"
	aria-pressed="false"
	title="切换主题"
>
	<span class="theme-toggle__icon" data-theme-toggle-icon aria-hidden="true">☀</span>
</button>

<script is:inline>
	const themeToggles = Array.from(document.querySelectorAll('[data-theme-toggle]'));
	const themeApi = window.__theme;

	if (themeApi && themeToggles.length > 0) {
		const syncThemeToggle = (theme) => {
			const isDark = theme === 'dark';

			themeToggles.forEach((toggle) => {
				if (!(toggle instanceof HTMLButtonElement)) return;

				const icon = toggle.querySelector('[data-theme-toggle-icon]');

				toggle.setAttribute('aria-pressed', String(isDark));
				toggle.setAttribute('aria-label', isDark ? '切换到浅色主题' : '切换到深色主题');
				toggle.setAttribute('title', isDark ? '切换到浅色主题' : '切换到深色主题');

				if (icon instanceof HTMLElement) {
					icon.textContent = isDark ? '☾' : '☀';
				}
			});
		};

		const getCurrentTheme = () =>
			document.documentElement.classList.contains('dark') ? 'dark' : 'light';

		syncThemeToggle(getCurrentTheme());

		window.addEventListener('theme-change', (event) => {
			syncThemeToggle(event.detail);
		});

		themeToggles.forEach((toggle) => {
			if (!(toggle instanceof HTMLButtonElement)) return;

			toggle.addEventListener('click', () => {
				const nextTheme = getCurrentTheme() === 'dark' ? 'light' : 'dark';
				syncThemeToggle(themeApi.setTheme(nextTheme));
			});
		});
	}
</script>

<style>
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: none;
		border-bottom: 4px solid transparent;
		border-radius: 0;
		background: transparent;
		color: rgb(var(--color-text-strong));
		cursor: pointer;
		font: inherit;
		line-height: 1;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.theme-toggle:hover {
		color: var(--accent);
	}

	.theme-toggle:focus-visible {
		outline: 2px solid rgba(var(--accent-rgb), 0.55);
		outline-offset: 2px;
	}

	.theme-toggle:active {
		transform: translateY(1px);
	}

	.theme-toggle__icon {
		display: block;
		font-size: 1.15rem;
	}
</style>
