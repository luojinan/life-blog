---
import { getCollection } from 'astro:content';
import { countChineseCharacters } from '../utils/countChineseCharacters';

interface Props {
	maxWidth?: string;
}

const { maxWidth = '720px' } = Astro.props;

const posts = await getCollection('blog');
const totalPostCount = posts.length;
const totalWordCount = posts.reduce(
	(sum, post) => sum + countChineseCharacters(post.body ?? ''),
	0,
);
---

<footer class="blog-footer" style={`--blog-footer-max-width: ${maxWidth};`}>
	<div class="blog-footer-inner">共{totalPostCount}篇 · {totalWordCount}字</div>
</footer>

<style>
	.blog-footer {
		width: min(var(--blog-footer-max-width), calc(100% - 2rem));
		margin: 2.75rem auto 0;
	}

	.blog-footer-inner {
		display: flex;
		justify-content: flex-end;
		color: rgb(var(--color-text-muted));
		font-size: 0.92rem;
		line-height: 1.5;
		text-align: right;
	}

	@media (max-width: 720px) {
		.blog-footer {
			width: min(100%, calc(100% - 1rem));
			margin-top: 2rem;
		}
	}
</style>
