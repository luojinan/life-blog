---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="nav-end">
			<div class="internal-links" aria-label="Primary">
				<HeaderLink href="/" activeMatch="/blog" aria-label="Home" title="Home">
					<span class="sr-only">Home</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
						<path
							fill="currentColor"
							d="M12.97 2.59a1.5 1.5 0 0 0-1.94 0l-7.5 6.363A1.5 1.5 0 0 0 3 10.097V19.5A1.5 1.5 0 0 0 4.5 21h4.75a.75.75 0 0 0 .75-.75v-4.5a2 2 0 0 1 4 0v4.5c0 .414.336.75.75.75h4.75a1.5 1.5 0 0 0 1.5-1.5v-9.403a1.5 1.5 0 0 0-.53-1.144l-7.5-6.363Z"
						></path>
					</svg>
				</HeaderLink>
				<HeaderLink href="/about" aria-label="About" title="About">
					<span class="sr-only">About</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
						<path
							fill="currentColor"
							d="M12 12.25a4.12 4.12 0 1 0 0-8.24 4.12 4.12 0 0 0 0 8.24Zm0-1.5a2.62 2.62 0 1 1 0-5.24 2.62 2.62 0 0 1 0 5.24ZM5.25 20a.75.75 0 0 1-.75-.75 7.5 7.5 0 0 1 15 0 .75.75 0 0 1-1.5 0 6 6 0 0 0-12 0 .75.75 0 0 1-.75.75Z"
						></path>
					</svg>
				</HeaderLink>
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgb(var(--color-bg));
		border-bottom: 1px solid rgb(var(--color-border));
		box-shadow: 0 8px 24px rgba(var(--color-shadow), 0.08);
	}
	h2 {
		margin: 0;
		font-size: 1em;
		flex: 1 1 auto;
		min-width: 0;
	}

	h2 a,
	h2 a.active {
		color: rgb(var(--color-text-strong));
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
		min-height: 4.5rem;
	}
	nav a {
		padding: 1em 0.35em;
		color: rgb(var(--color-text-muted));
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	nav a:hover {
		color: rgb(var(--color-text-strong));
	}
	nav a.active {
		color: rgb(var(--color-text-strong));
		text-decoration: none;
		border-bottom-color: rgb(var(--color-text-strong));
	}
	.internal-links,
	.nav-end {
		display: flex;
		align-items: center;
	}
	.internal-links,
	.nav-end {
		gap: 0.45rem;
	}
	.internal-links :global(a) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.75rem;
		padding-inline: 0.55rem;
	}
	.internal-links :global(svg) {
		display: block;
	}
	.nav-end {
		margin-left: auto;
		flex-shrink: 0;
		flex-wrap: nowrap;
	}
		@media (max-width: 720px) {
			header {
				padding-block: 0.35rem;
			}
			nav {
				min-height: 0;
				flex-wrap: nowrap;
			}
			.internal-links {
				gap: 0.35rem;
			}
			.internal-links :global(a) {
				min-width: 2.25rem;
				padding: 0.7rem 0.3rem;
			}
			.internal-links :global(svg) {
				width: 18px;
				height: 18px;
			}
		}
	</style>
