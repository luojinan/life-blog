---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="nav-end">
			<div class="internal-links" aria-label="Primary">
				<HeaderLink href="/" activeMatch="/blog" aria-label="Blog" title="Blog">
					<span class="sr-only">Blog</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
						<path
							fill="currentColor"
							d="M6.75 3.5h8.69c.59 0 1.16.23 1.58.66l2.82 2.82c.42.42.66.99.66 1.58v11.69A2.75 2.75 0 0 1 17.75 23h-11A2.75 2.75 0 0 1 4 20.25v-14.0A2.75 2.75 0 0 1 6.75 3.5Zm0 1.5c-.69 0-1.25.56-1.25 1.25v14c0 .69.56 1.25 1.25 1.25h11c.69 0 1.25-.56 1.25-1.25V9.5h-3a1.75 1.75 0 0 1-1.75-1.75v-3.25Zm8.75.31v2.44c0 .14.11.25.25.25h2.44ZM8 11.25c0-.41.34-.75.75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5A.75.75 0 0 1 8 11.25Zm0 3.5c0-.41.34-.75.75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5A.75.75 0 0 1 8 14.75Zm0 3.5c0-.41.34-.75.75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5A.75.75 0 0 1 8 18.25Z"
						></path>
					</svg>
				</HeaderLink>
				<HeaderLink href="/about" aria-label="About" title="About">
					<span class="sr-only">About</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
						<path
							fill="currentColor"
							d="M12 12.25a4.12 4.12 0 1 0 0-8.24 4.12 4.12 0 0 0 0 8.24Zm0-1.5a2.62 2.62 0 1 1 0-5.24 2.62 2.62 0 0 1 0 5.24ZM5.25 20a.75.75 0 0 1-.75-.75 7.5 7.5 0 0 1 15 0 .75.75 0 0 1-1.5 0 6 6 0 0 0-12 0 .75.75 0 0 1-.75.75Z"
						></path>
					</svg>
				</HeaderLink>
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgb(var(--color-bg-elevated));
		border-bottom: 1px solid rgba(var(--color-border), 0.65);
		box-shadow: 0 10px 30px rgba(var(--color-shadow), 0.12);
	}
	h2 {
		margin: 0;
		font-size: 1em;
		flex: 1 1 auto;
		min-width: 0;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
		min-height: 4.5rem;
	}
	nav a {
		padding: 1em 0.35em;
		color: rgb(var(--color-text-strong));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.internal-links,
	.nav-end {
		display: flex;
		align-items: center;
	}
	.internal-links,
	.nav-end {
		gap: 0.45rem;
	}
	.internal-links :global(a) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.75rem;
		padding-inline: 0.55rem;
	}
	.internal-links :global(svg) {
		display: block;
	}
	.nav-end {
		margin-left: auto;
		flex-shrink: 0;
		flex-wrap: nowrap;
	}
	@media (max-width: 720px) {
		header {
			padding-block: 0.35rem;
		}
		nav {
			min-height: 0;
			flex-wrap: nowrap;
		}
	}
</style>
